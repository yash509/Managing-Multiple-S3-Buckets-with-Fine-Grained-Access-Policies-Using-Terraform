Step 3: Create the "main.tf" file

# Create S3 buckets for Dev, Staging, and Prod using for_each
resource "aws_s3_bucket" "env_buckets" {
  for_each = var.KKE_ENV_TAGS

  bucket = each.value["bucket_name"]

  tags = {
    Name        = each.value["bucket_name"]
    Environment = each.key
    Owner       = each.value["owner"]
    Backup      = try(each.value["backup"], "false")
  }

  lifecycle {
    ignore_changes = [tags]
  }
}

# Lifecycle rules for staging and prod buckets
resource "aws_s3_bucket_lifecycle_configuration" "env_buckets_lifecycle" {
  for_each = {
    for k, v in var.KKE_ENV_TAGS : k => v if try(v["backup"], "false") == "true"
  }

  bucket = aws_s3_bucket.env_buckets[each.key].id

  rule {
    id     = "MoveToGlacier"
    status = "Enabled"

    transition {
      days          = 30
      storage_class = "GLACIER"
    }
  }
}

# Public read bucket policy
resource "aws_s3_bucket_policy" "env_buckets_policy" {
  for_each = var.KKE_ENV_TAGS

  bucket = aws_s3_bucket.env_buckets[each.key].id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "PublicReadGetObject"
        Effect    = "Allow"
        Principal = "*"
        Action    = ["s3:GetObject"]
        Resource  = "${aws_s3_bucket.env_buckets[each.key].arn}/*"
      }
    ]
  })

  depends_on = [aws_s3_bucket.env_buckets]
}



Step 4: Create the "variables.tf" file

variable "KKE_ENV_TAGS" {
  description = "Map of environment-specific metadata for S3 buckets"
  type        = map(map(string))
}



Step 5: Create the "terraform.tfvars" file

KKE_ENV_TAGS = {
  Dev = {
    bucket_name = "devops-dev-bucket-12822"
    owner       = "Alice"
    backup      = "false"
  }
  Staging = {
    bucket_name = "devops-staging-bucket-12822"
    owner       = "Bob"
    backup      = "true"
  }
  Prod = {
    bucket_name = "devops-prod-bucket-12822"
    owner       = "Carol"
    backup      = "true"
  }
}



Step 7: Create the "outputs.tf" file

output "kke_bucket_names" {
  description = "Names of the S3 buckets created"
  value       = [for b in aws_s3_bucket.env_buckets : b.bucket]
}



